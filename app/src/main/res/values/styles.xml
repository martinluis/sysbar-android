<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SideMenuTextStyle" parent="android:Widget.TextView">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextInputLayoutStyle">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundMode">outline</item>
    </style>

    <style name="OutlinedButtonPrimary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="OutlinedButtonError" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/error</item>
        <item name="strokeColor">@color/error</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="OutlinedButtonSuccess" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/success</item>
        <item name="strokeColor">@color/success</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>