<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    tools:context=".fragments.OrderFragment">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="5dp"
        android:layout_weight="1.5">

        <com.lcmm.sysbar.android.components.SearchProductView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_weight="1.5"/>

        <com.lcmm.sysbar.android.components.CustomView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:borderColor="@color/gray_3"
            android:orientation="horizontal"
            android:gravity="center"
            app:color="@color/gray_1"
            app:isRound="false">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/payButton"
                style="@style/OutlinedButtonPrimary"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:layout_marginEnd="20dp"
                android:text="@string/order_button_change" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/moveButton"
                style="@style/OutlinedButtonPrimary"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="@string/order_button_print_ticket" />
        </com.lcmm.sysbar.android.components.CustomView>
    </androidx.appcompat.widget.LinearLayoutCompat>


    <com.lcmm.sysbar.android.components.CustomView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="5dp"
        android:layout_weight="1"
        app:isRound="false"
        app:borderColor="@color/gray_2">
        <com.lcmm.sysbar.android.components.OrderSummaryView
            android:id="@+id/orderSummaryView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </com.lcmm.sysbar.android.components.CustomView>

</LinearLayout>